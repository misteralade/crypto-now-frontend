{
  "name": "crypto-now-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:debug-anonymous": "playwright test tests/anonymous-trading.spec.ts --debug --grep \"Complete Transaction Flow\"",
    "test:headed-anonymous": "playwright test tests/anonymous-trading.spec.ts --headed --grep \"Complete Transaction Flow\"",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "@material-tailwind/react": "^2.1.10",
    "@reduxjs/toolkit": "^2.9.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.85.2",
    "@tanstack/react-router": "^1.131.10",
    "@tanstack/react-router-devtools": "^1.131.10",
    "axios": "^1.11.0",
    "formik": "^2.4.9",
    "lucide-react": "^0.539.0",
    "millify": "^6.1.0",
    "moment": "^2.30.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-toastify": "^11.0.5",
    "redux-persist": "^6.0.0",
    "tailwindcss": "^4.1.11",
    "zod": "^4.0.17",
    "zod-formik-adapter": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
